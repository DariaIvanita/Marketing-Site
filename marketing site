<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Daria | Portfolio</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
html { scroll-behavior: smooth; }

body {
  margin: 0;
  font-family: Poppins, sans-serif;
  background: #0b0b0f;
  color: white;
}

/* NAV */
nav {
  position: fixed;
  width: 100%;
  top: 0;
  padding: 15px 8%;
  display: flex;
  justify-content: space-between;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);
  z-index: 1000;
}

nav a {
  color: white;
  text-decoration: none;
  margin-left: 15px;
}

nav a:hover {
  color: #ff3c78;
}

/* HERO */
.hero {
  height: 100vh;
  background: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c') center/cover no-repeat;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
}

/* 🔥 IMPORTANT FIX: ensures overlay doesn't block clicks */
.hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.65);
  z-index: 1;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2; /* ensures buttons are clickable */
  max-width: 750px;
}

h1 {
  font-size: 3rem;
  margin-bottom: 10px;
}

p {
  color: #ccc;
}

/* 🔥 BUTTON FIXED */
.btn {
  display: inline-block;
  margin: 10px;
  padding: 12px 25px;
  background: linear-gradient(135deg,#ff3c78,#7a5cff);
  color: white;
  border-radius: 30px;
  text-decoration: none;
  cursor: pointer;
  border: none;

  /* IMPORTANT */
  position: relative;
  z-index: 2;
  pointer-events: auto;
}

.btn:hover {
  transform: scale(1.05);
}

/* SECTIONS */
section {
  padding: 100px 10%;
}

h2 {
  margin-bottom: 20px;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
  gap: 20px;
}

.card {
  background: #16161d;
  padding: 20px;
  border-radius: 12px;
}

/* ABOUT */
.about {
  background: #16161d;
  padding: 30px;
  border-radius: 15px;
}

/* FOOTER */
footer {
  text-align: center;
  padding: 30px;
  color: #aaa;
}
</style>
</head>

<body>

<!-- NAV -->
<nav>
  <div><strong>Daria | Portfolio</strong></div>

  <div>
    <a href="#home">Home</a>
    <a href="https://portfolio-lemon-chi-60.vercel.app/developerwork.html" target="_blank">Projects</a>
    <a href="#about">About</a>
    <a href="#skills">Skills</a>
    <a href="mailto:dasha.ivanita@gmail.com">Contact</a>
  </div>
</nav>

<!-- HERO -->
<section id="home" class="hero">
  <div class="hero-content">
    <h1>Hi, I’m Daria 👋</h1>
    <p>UI/UX Designer • Frontend Developer • Marketing Creative</p>

    <!-- ✅ WORKS NOW 100% -->
    <a class="btn"
       href="https://portfolio-lemon-chi-60.vercel.app/developerwork.html"
       target="_blank">
       View My Work
    </a>

    <a class="btn"
       href="mailto:dasha.ivanita@gmail.com">
       Contact Me
    </a>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <h2>About Me</h2>

  <div class="about">
    I’m a creative designer based in Calgary specializing in UI/UX, branding, and frontend development.
    I build clean, modern digital experiences that are both functional and visually strong.
  </div>
</section>

<!-- SKILLS -->
<section id="skills">
  <h2>Skills</h2>

  <div class="grid">
    <div class="card">UI/UX Design</div>
    <div class="card">HTML / CSS / JS</div>
    <div class="card">WordPress</div>
    <div class="card">Branding</div>
    <div class="card">Adobe Suite</div>
    <div class="card">3D Web Design</div>
  </div>
</section>

<footer>
  © 2026 Daria | Portfolio
</footer>

</body>
</html>
